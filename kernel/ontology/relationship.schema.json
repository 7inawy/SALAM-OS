{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://salam-os/kernel/ontology/relationship.schema.json",
  "title": "Relationship",
  "description": "A persistent, Evidence-backed commercial connection between two entities (Merchants or Organizations). The edge primitive of the Commercial Graph, derived from Events and Transactions. See kernel/ontology/relationship.md for full canonical definition.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "relationship_id",
    "party_a",
    "party_b",
    "relationship_type",
    "direction",
    "strength",
    "event_refs",
    "status",
    "formed_at",
    "interaction_count",
    "outcome_summary",
    "flags",
    "version",
    "archived"
  ],
  "properties": {
    "relationship_id": {
      "type": "string",
      "format": "uuid",
      "description": "Canonical identifier. Never reused."
    },
    "party_a": {
      "$ref": "#/$defs/EntityRef",
      "description": "First entity. Lexicographically smaller entity_id of the pair."
    },
    "party_b": {
      "$ref": "#/$defs/EntityRef",
      "description": "Second entity. Lexicographically larger entity_id of the pair."
    },
    "relationship_type": {
      "type": "string",
      "description": "Nature of the connection. Core types: buyer_seller, supplier, logistics_partner, financial_guarantor, platform_merchant, co_ownership, referral, dispute_history. Extended at Specification layer."
    },
    "direction": {
      "type": "string",
      "enum": ["unidirectional_a_to_b", "unidirectional_b_to_a", "bidirectional"]
    },
    "strength": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Current relationship strength. Mutable/recalculable from Event/Transaction volume, recency, and outcome quality."
    },
    "event_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      },
      "minItems": 1,
      "description": "Append-only. Events that established or reinforce this Relationship."
    },
    "transaction_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      },
      "description": "Append-only. Transactions between these parties."
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      },
      "description": "Append-only. Direct Evidence supporting this Relationship (e.g. signed contracts)."
    },
    "status": {
      "type": "string",
      "enum": ["forming", "active", "dormant", "terminated"]
    },
    "formed_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this Relationship was first recognized by the system."
    },
    "last_interaction_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Timestamp of the most recent Event or Transaction between these parties."
    },
    "interaction_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Total count of Events and Transactions. Monotonically increasing."
    },
    "outcome_summary": {
      "$ref": "#/$defs/OutcomeSummary"
    },
    "flags": {
      "type": "array",
      "items": { "$ref": "#/$defs/Flag" },
      "description": "Append-only."
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "archived": {
      "type": "boolean"
    }
  },
  "$defs": {
    "EntityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["merchant", "organization"]
        },
        "entity_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "OutcomeSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_events",
        "total_transactions",
        "completed_transactions",
        "failed_transactions",
        "disputed_transactions",
        "completion_rate",
        "dispute_rate",
        "last_calculated_at"
      ],
      "properties": {
        "total_events": {
          "type": "integer",
          "minimum": 0
        },
        "total_transactions": {
          "type": "integer",
          "minimum": 0
        },
        "completed_transactions": {
          "type": "integer",
          "minimum": 0
        },
        "failed_transactions": {
          "type": "integer",
          "minimum": 0
        },
        "disputed_transactions": {
          "type": "integer",
          "minimum": 0
        },
        "completion_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "dispute_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "total_value": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Cumulative value of all Transactions in normalized currency. Currency normalization is a Specification concern."
        },
        "last_calculated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Flag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["flag_id", "flag_type", "raised_by", "raised_at"],
      "properties": {
        "flag_id": {
          "type": "string",
          "format": "uuid"
        },
        "flag_type": {
          "type": "string"
        },
        "raised_by": {
          "type": "string"
        },
        "raised_at": {
          "type": "string",
          "format": "date-time"
        },
        "evidence_ref": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "resolved_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "resolution_note": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
