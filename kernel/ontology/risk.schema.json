{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://salam-os/kernel/ontology/risk.schema.json",
  "title": "Risk",
  "description": "A computed, Evidence-backed assessment of the probability and severity of adverse outcomes in a commercial interaction. Prospective, context-scoped, independent of Trust. See kernel/ontology/risk.md for full canonical definition.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "risk_id",
    "subject_ref",
    "context",
    "score",
    "dimensions",
    "severity",
    "confidence",
    "evidence_weight",
    "flags",
    "status",
    "valid_for",
    "computed_at",
    "computed_by",
    "version",
    "archived"
  ],
  "properties": {
    "risk_id": {
      "type": "string",
      "format": "uuid"
    },
    "subject_ref": {
      "$ref": "#/$defs/EntityRef"
    },
    "context": {
      "$ref": "#/$defs/RiskContext"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Composite Risk score. 0 = minimal, 1 = maximum. Mutable/recalculable."
    },
    "dimensions": {
      "$ref": "#/$defs/RiskDimensions"
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "description": "Derived categorical label: low 0-0.25, medium 0.25-0.5, high 0.5-0.75, critical 0.75-1.0."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in the Risk score. Low = sparse evidence."
    },
    "evidence_weight": {
      "$ref": "#/$defs/EvidenceWeight"
    },
    "flags": {
      "type": "array",
      "items": { "$ref": "#/$defs/RiskFlag" },
      "description": "Append-only. Active risk signals contributing to or escalating this assessment."
    },
    "status": {
      "type": "string",
      "enum": ["initializing", "active", "stale", "escalated", "resolved"]
    },
    "escalation_reason": {
      "type": ["string", "null"],
      "description": "Required if status is escalated. Set once."
    },
    "valid_for": {
      "$ref": "#/$defs/ValidityWindow"
    },
    "computed_at": {
      "type": "string",
      "format": "date-time"
    },
    "computed_by": {
      "type": "string",
      "description": "Engine version that produced this score."
    },
    "history": {
      "type": "array",
      "items": { "$ref": "#/$defs/RiskHistoryEntry" },
      "description": "Append-only log of prior scores."
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "archived": {
      "type": "boolean"
    }
  },
  "$defs": {
    "EntityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["merchant", "organization"]
        },
        "entity_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "RiskContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transaction_value_band", "market"],
      "properties": {
        "transaction_value": {
          "type": ["number", "null"],
          "exclusiveMinimum": 0
        },
        "transaction_value_band": {
          "type": "string",
          "enum": ["micro", "small", "medium", "large"]
        },
        "market": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "counterparty_ref": {
          "type": ["string", "null"],
          "format": "uuid"
        },
        "product_type": {
          "type": ["string", "null"]
        },
        "payment_method": {
          "type": ["string", "null"]
        }
      }
    },
    "RiskDimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "behavioral", "financial", "network", "market", "concentration"],
      "properties": {
        "identity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Risk from uncertain or disputed identity."
        },
        "behavioral": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Risk from adverse behavioral patterns."
        },
        "financial": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Risk from financial exposure and payment failure history."
        },
        "network": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Contagion risk from commercial network proximity to high-risk entities."
        },
        "market": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Risk from operating environment: volatility, regulation, infrastructure."
        },
        "concentration": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Risk from over-dependence on a single counterparty, market, or category."
        }
      }
    },
    "EvidenceWeight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_count", "knowledge_count", "oldest_evidence_at", "newest_evidence_at", "primary_drivers"],
      "properties": {
        "evidence_count": { "type": "integer", "minimum": 0 },
        "knowledge_count": { "type": "integer", "minimum": 0 },
        "oldest_evidence_at": { "type": "string", "format": "date-time" },
        "newest_evidence_at": { "type": "string", "format": "date-time" },
        "primary_drivers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref_id", "ref_type", "dimension", "contribution_weight"],
            "properties": {
              "ref_id": { "type": "string", "format": "uuid" },
              "ref_type": { "type": "string", "enum": ["evidence", "knowledge"] },
              "dimension": {
                "type": "string",
                "enum": ["identity", "behavioral", "financial", "network", "market", "concentration"]
              },
              "contribution_weight": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    },
    "RiskFlag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["flag_id", "flag_type", "severity", "raised_by", "raised_at"],
      "properties": {
        "flag_id": { "type": "string", "format": "uuid" },
        "flag_type": {
          "type": "string",
          "description": "e.g. fraud_network_proximity, sanctions_list_match, high_dispute_velocity, identity_conflict, abnormal_transaction_pattern."
        },
        "severity": { "type": "string", "enum": ["warning", "high", "critical"] },
        "raised_by": { "type": "string" },
        "raised_at": { "type": "string", "format": "date-time" },
        "evidence_ref": { "type": ["string", "null"], "format": "uuid" },
        "resolved_at": { "type": ["string", "null"], "format": "date-time" },
        "resolution_note": { "type": ["string", "null"] }
      }
    },
    "ValidityWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid_from", "decay_model"],
      "properties": {
        "valid_from": { "type": "string", "format": "date-time" },
        "valid_until": { "type": ["string", "null"], "format": "date-time" },
        "decay_model": { "type": "string", "enum": ["none", "linear", "exponential"] }
      }
    },
    "RiskHistoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "severity", "dimensions", "computed_at", "trigger"],
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "dimensions": { "$ref": "#/$defs/RiskDimensions" },
        "computed_at": { "type": "string", "format": "date-time" },
        "trigger": {
          "type": "string",
          "enum": ["new_evidence", "evidence_decay", "relationship_update", "flag_raised", "flag_resolved", "scheduled", "manual"]
        }
      }
    }
  }
}
