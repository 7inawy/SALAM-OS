{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://salam-os/kernel/ontology/trust.schema.json",
  "title": "Trust",
  "description": "A computed, Evidence-backed assessment of the reliability and commercial integrity of a Merchant or Organization. Multi-dimensional, context-scoped, continuously updated. See kernel/ontology/trust.md for full canonical definition.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trust_id",
    "subject_ref",
    "context",
    "score",
    "dimensions",
    "confidence",
    "evidence_weight",
    "status",
    "valid_for",
    "computed_at",
    "computed_by",
    "version",
    "archived"
  ],
  "properties": {
    "trust_id": {
      "type": "string",
      "format": "uuid"
    },
    "subject_ref": {
      "$ref": "#/$defs/EntityRef"
    },
    "context": {
      "$ref": "#/$defs/TrustContext"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Composite Trust score. 0 = no trust, 1 = full trust. Mutable/recalculable."
    },
    "dimensions": {
      "$ref": "#/$defs/TrustDimensions"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in the Trust score itself. Low = sparse evidence."
    },
    "evidence_weight": {
      "$ref": "#/$defs/EvidenceWeight"
    },
    "status": {
      "type": "string",
      "enum": ["initializing", "active", "stale", "suspended", "revoked"]
    },
    "suspension_reason": {
      "type": ["string", "null"],
      "description": "Required if status is suspended or revoked. Set once."
    },
    "valid_for": {
      "$ref": "#/$defs/ValidityWindow"
    },
    "computed_at": {
      "type": "string",
      "format": "date-time"
    },
    "computed_by": {
      "type": "string",
      "description": "Engine version that produced this score."
    },
    "history": {
      "type": "array",
      "items": { "$ref": "#/$defs/TrustHistoryEntry" },
      "description": "Append-only log of prior scores."
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "archived": {
      "type": "boolean"
    }
  },
  "$defs": {
    "EntityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_type", "entity_id"],
      "properties": {
        "entity_type": {
          "type": "string",
          "enum": ["merchant", "organization"]
        },
        "entity_id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "TrustContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transaction_value_band", "market"],
      "properties": {
        "transaction_value_band": {
          "type": "string",
          "enum": ["micro", "small", "medium", "large"],
          "description": "micro <$100, small $100-$1k, medium $1k-$10k, large >$10k."
        },
        "market": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "counterparty_type": {
          "type": ["string", "null"],
          "description": "e.g. marketplace, bank, logistics_provider. Null = general."
        },
        "product_type": {
          "type": ["string", "null"]
        }
      }
    },
    "TrustDimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "fulfillment", "consistency", "financial", "network"],
      "properties": {
        "identity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Identity verification confidence."
        },
        "fulfillment": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Commitment completion reliability."
        },
        "consistency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Behavioral consistency over time."
        },
        "financial": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Financial behavior soundness."
        },
        "network": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Indirect trust signal from commercial network neighbors."
        }
      }
    },
    "EvidenceWeight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_count", "knowledge_count", "oldest_evidence_at", "newest_evidence_at", "primary_drivers"],
      "properties": {
        "evidence_count": {
          "type": "integer",
          "minimum": 0
        },
        "knowledge_count": {
          "type": "integer",
          "minimum": 0
        },
        "oldest_evidence_at": {
          "type": "string",
          "format": "date-time"
        },
        "newest_evidence_at": {
          "type": "string",
          "format": "date-time"
        },
        "primary_drivers": {
          "type": "array",
          "description": "Top contributors to the score, for explainability.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["ref_id", "ref_type", "dimension", "contribution_weight"],
            "properties": {
              "ref_id": {
                "type": "string",
                "format": "uuid",
                "description": "Evidence ID or Knowledge ID."
              },
              "ref_type": {
                "type": "string",
                "enum": ["evidence", "knowledge"]
              },
              "dimension": {
                "type": "string",
                "enum": ["identity", "fulfillment", "consistency", "financial", "network"]
              },
              "contribution_weight": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        }
      }
    },
    "ValidityWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valid_from", "decay_model"],
      "properties": {
        "valid_from": {
          "type": "string",
          "format": "date-time"
        },
        "valid_until": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "decay_model": {
          "type": "string",
          "enum": ["none", "linear", "exponential"]
        }
      }
    },
    "TrustHistoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "dimensions", "computed_at", "trigger"],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "dimensions": {
          "$ref": "#/$defs/TrustDimensions"
        },
        "computed_at": {
          "type": "string",
          "format": "date-time"
        },
        "trigger": {
          "type": "string",
          "enum": ["new_evidence", "evidence_decay", "relationship_update", "scheduled", "manual"]
        }
      }
    }
  }
}
